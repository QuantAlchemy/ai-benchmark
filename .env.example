# Optional local replica root. Relative paths resolve from the project root.
# AI_BENCHMARK_DATA_ROOT=./data

# Optional remote sync credentials. Keep these server-only; never prefix them with VITE_.
AI_BENCHMARK_SYNC_URL=https://your-deployment.convex.site
AI_BENCHMARK_SYNC_CLIENT_ID=replace-with-provisioned-client-id
AI_BENCHMARK_SYNC_CLIENT_TOKEN=replace-with-provisioned-client-token
